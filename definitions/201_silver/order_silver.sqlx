config {
  type: "table",
  name: "orders_silver",
  description: "Deduplicated orders using the latest record per order_id"
}

SELECT
  * EXCEPT(rn)
FROM (
  SELECT
    *,
    ROW_NUMBER() OVER (
      PARTITION BY order_id 
      ORDER BY order_date DESC
    ) AS rn
  FROM ${ref("orders_bronze")} -- This creates the dependency link
)
WHERE rn = 1